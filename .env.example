# Copy this file to `.env` at the repo root and fill in real values.
# Never commit the real `.env` file — it is already gitignored.

# ======================
#  Database (Neon PostgreSQL)
# ======================
# Prisma-style connection string. Get this from the Neon dashboard
# (project > branch > connection string). Neon requires SSL.
DATABASE_URL="postgresql://user:password@ep-example-000000.region.aws.neon.tech/medilink?sslmode=require"

# Used by .github/workflows/neon_workflow.yml to create/delete a Neon
# branch per pull request.
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_DATA_API_URL=

# Neon Auth: identity/credentials (registration, login, sessions, JWTs)
# live here rather than in our own database. Get these from the Neon
# dashboard (project > Auth > Configuration) after enabling Auth.
Auth_URL=
JWKS_URL=

# ======================
#  Backend (NestJS) API
# ======================
NODE_ENV=development
PORT=3000

# ======================
#  Frontend (Next.js) Neon Auth session cookies. Local to the Next.js
#  app's own cookie signing — generate with:
#  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ======================
NEON_AUTH_COOKIE_SECRET=

# ======================
#  Redis (cache / pubsub)
# ======================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================
#  Object Storage (MinIO)
# ======================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medilink-reports

# ======================
#  AI Service (FastAPI)
# ======================
AI_SERVICE_PORT=8000
# Optional — only needed once real LLM-backed summarization replaces
# the MVP's simulated summarization (Phase 7).
OPENAI_API_KEY=
HF_API_KEY=

# ======================
#  Maps / ETA
# ======================
GOOGLE_MAPS_API_KEY=

# ======================
#  Frontend (Next.js)
# ======================
FRONTEND_PORT=3001
# Server-side only (used in Server Components/Actions, never sent to the browser)
API_BASE_URL=http://localhost:3000/api/v1

# ======================
#  Email delivery (Resend) — takes over Neon Auth's OTP/magic-link emails
#  via the send.otp / send.magic_link webhooks instead of Neon's shared
#  sender. EMAIL_FROM must be a verified sender/domain in Resend; the
#  onboarding@resend.dev default can only send to your own Resend account
#  email until you verify a real domain.
# ======================
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Public HTTPS URL Neon Auth webhooks POST to (cloudflared/ngrok tunnel in
# dev, your real domain in prod). Re-run the webhook registration script
# whenever this changes.
NEON_AUTH_WEBHOOK_URL=
