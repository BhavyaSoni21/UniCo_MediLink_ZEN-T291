generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model doctor_specializations {
  id                  Int     @id @default(autoincrement()) @db.SmallInt
  specialization_name String  @unique @db.VarChar(100)
  description         String?

  hospital_specialties hospital_specialties[]
  doctors              doctors[]
}

model medicines {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  generic_name String    @db.VarChar(255)
  brand_name   String?   @db.VarChar(255)
  manufacturer String?   @db.VarChar(255)
  dosage_form  String?   @db.VarChar(100)
  strength     String?   @db.VarChar(100)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  pharmacy_inventory    pharmacy_inventory[]
  medicine_reservations medicine_reservations[]

  @@index([generic_name], map: "idx_medicines_generic_name")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model roles {
  id          Int      @id @default(autoincrement()) @db.SmallInt
  role_name   String   @unique @db.VarChar(50)
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users[]
}

model system_configuration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  config_key   String    @unique @db.VarChar(100)
  config_value String
  description  String?
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model users {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id            Int?                 @db.SmallInt
  email              String?              @unique @db.VarChar(255)
  phone              String?              @unique @db.VarChar(20)
  name               String?              @db.VarChar(255)
  password_hash      String?              @db.VarChar(255)
  is_email_verified  Boolean              @default(false)
  is_phone_verified  Boolean              @default(false)
  account_status     account_status_enum  @default(ACTIVE)
  last_login         DateTime?            @db.Timestamptz(6)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  // Null until the post-login role-selection step (RoleForm) runs — that's
  // the signal the dashboard/RolesGuard use to tell "no role chosen yet"
  // apart from "role explicitly set". Don't default this at sign-up.
  roles              roles?               @relation(fields: [role_id], references: [id], map: "fk_user_role")
  patients           patients?
  doctors            doctors?
  record_access_logs record_access_logs[]

  @@index([email], map: "idx_users_email")
  @@index([phone], map: "idx_users_phone")
  @@index([role_id], map: "idx_users_role")
  @@index([account_status], map: "idx_users_status")
}

// --- Patient Management (Phase 2) ---------------------------------------

model patients {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String            @unique @db.Uuid
  first_name        String?           @db.VarChar(100)
  last_name         String?           @db.VarChar(100)
  date_of_birth     DateTime?         @db.Date
  gender            gender_enum?
  blood_group       blood_group_enum? @default(UNKNOWN)
  height_cm         Decimal?          @db.Decimal(5, 2)
  weight_kg         Decimal?          @db.Decimal(5, 2)
  profile_photo_key String?           @db.VarChar(500)
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  users              users                @relation(fields: [user_id], references: [id], map: "fk_patient_user")
  address            addresses?
  emergency_contacts emergency_contacts[]
  medical_conditions medical_conditions[]
  allergies          allergies[]
  medications        medications[]
  insurances         insurances[]
  medical_records    medical_records[]
  consents           consents[]
  triage_sessions          triage_sessions[]
  vitals_readings          vitals_readings[]
  hospital_recommendations hospital_recommendations[]
  appointments             appointments[]
  medicine_reservations    medicine_reservations[]

  @@index([user_id], map: "idx_patients_user")
}

model addresses {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id     String   @unique @db.Uuid
  address_line_1 String   @db.VarChar(255)
  address_line_2 String?  @db.VarChar(255)
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  country        String?  @db.VarChar(100)
  pincode        String?  @db.VarChar(20)
  latitude       Decimal? @db.Decimal(9, 6)
  longitude      Decimal? @db.Decimal(9, 6)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_address_patient")
}

model emergency_contacts {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id   String  @db.Uuid
  name         String  @db.VarChar(150)
  relationship String? @db.VarChar(50)
  phone        String  @db.VarChar(20)
  email        String? @db.VarChar(255)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_emergency_contact_patient")

  @@index([patient_id], map: "idx_emergency_contacts_patient")
}

model medical_conditions {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id     String                @db.Uuid
  condition_name String                @db.VarChar(255)
  diagnosis_date DateTime?             @db.Date
  status         condition_status_enum @default(ACTIVE)
  notes          String?
  created_at     DateTime              @default(now()) @db.Timestamptz(6)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_condition_patient")

  @@index([patient_id], map: "idx_medical_conditions_patient")
}

model allergies {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id   String                @db.Uuid
  allergy_name String                @db.VarChar(255)
  severity     allergy_severity_enum @default(UNKNOWN)
  reaction     String?
  created_at   DateTime              @default(now()) @db.Timestamptz(6)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_allergy_patient")

  @@index([patient_id], map: "idx_allergies_patient")
}

model medications {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id    String    @db.Uuid
  medicine_name String    @db.VarChar(255)
  dosage        String?   @db.VarChar(100)
  frequency     String?   @db.VarChar(100)
  start_date    DateTime? @db.Date
  end_date      DateTime? @db.Date
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_medication_patient")

  @@index([patient_id], map: "idx_medications_patient")
}

model insurances {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id    String    @db.Uuid
  provider_name String    @db.VarChar(255)
  policy_number String    @db.VarChar(100)
  coverage_type String?   @db.VarChar(100)
  valid_until   DateTime? @db.Date
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  patients patients @relation(fields: [patient_id], references: [id], map: "fk_insurance_patient")

  @@index([patient_id], map: "idx_insurances_patient")
}

// --- Medical Records & Consent (Phase 2) ---------------------------------
//
// medical_records.doctor_id and consents.granted_to_id intentionally have no
// FK constraint: they reference a users.id (a doctor/hospital/pharmacy-role
// account), since dedicated Doctor/Hospital entities don't exist until later
// phases. Prescription/PrescriptionMedicine/LabReport are deferred for the
// same reason — they're doctor-authored artifacts with no producing workflow
// yet.
//
// medical_records is soft-deleted (deleted_at), matching the codebase's
// existing account_status_enum.DELETED convention for users — a hard DELETE
// would cascade onto record_access_logs and wipe the very audit trail that's
// supposed to survive record removal.

model medical_records {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id  String           @db.Uuid
  doctor_id   String?          @db.Uuid
  record_type record_type_enum @default(CONSULTATION)
  visit_date  DateTime?        @db.Date
  summary     String?
  diagnosis   String?
  deleted_at  DateTime?        @db.Timestamptz(6)
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @updatedAt @db.Timestamptz(6)

  patients           patients             @relation(fields: [patient_id], references: [id], map: "fk_record_patient")
  medical_files      medical_files[]
  record_access_logs record_access_logs[]
  consents           consents[]

  @@index([patient_id], map: "idx_medical_records_patient")
}

model medical_files {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  medical_record_id String   @db.Uuid
  file_name         String   @db.VarChar(255)
  file_type         String   @db.VarChar(100)
  storage_key       String   @db.VarChar(500)
  file_size_bytes   Int?
  ocr_text          String?
  uploaded_at       DateTime @default(now()) @db.Timestamptz(6)

  medical_records medical_records @relation(fields: [medical_record_id], references: [id], map: "fk_file_record")

  @@index([medical_record_id], map: "idx_medical_files_record")
}

model consents {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id      String                    @db.Uuid
  granted_to_type consent_grantee_type_enum
  granted_to_id   String                    @db.Uuid
  record_id       String?                   @db.Uuid
  status          consent_status_enum       @default(ACTIVE)
  granted_at      DateTime                  @default(now()) @db.Timestamptz(6)
  revoked_at      DateTime?                 @db.Timestamptz(6)

  patients        patients         @relation(fields: [patient_id], references: [id], map: "fk_consent_patient")
  medical_records medical_records? @relation(fields: [record_id], references: [id], map: "fk_consent_record")

  @@index([patient_id], map: "idx_consents_patient")
  @@index([granted_to_id], map: "idx_consents_grantee")
  @@index([record_id], map: "idx_consents_record")
}

model record_access_logs {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  medical_record_id String                    @db.Uuid
  accessed_by       String                    @db.Uuid
  action            record_access_action_enum
  access_time       DateTime                  @default(now()) @db.Timestamptz(6)
  ip_address        String?                   @db.VarChar(45)

  medical_records medical_records @relation(fields: [medical_record_id], references: [id], map: "fk_access_log_record")
  users           users           @relation(fields: [accessed_by], references: [id], map: "fk_access_log_accessed_by")

  @@index([medical_record_id], map: "idx_access_logs_record")
  @@index([accessed_by], map: "idx_access_logs_accessor")
}

// --- AI Risk Prediction & Triage (Phase 3) --------------------------------

model triage_sessions {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id       String              @db.Uuid
  status           triage_status_enum  @default(STARTED)
  symptoms_summary String?
  risk_score       Int?
  urgency_level    urgency_level_enum?
  care_level       String?             @db.VarChar(100)
  ai_explanation   String?
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at       DateTime            @default(now()) @updatedAt @db.Timestamptz(6)

  patients                 patients                   @relation(fields: [patient_id], references: [id], map: "fk_triage_patient")
  symptoms                 symptoms[]
  vitals_readings          vitals_readings[]
  hospital_recommendations hospital_recommendations[]
  appointments             appointments[]

  @@index([patient_id], map: "idx_triage_patient")
}

model symptoms {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  triage_session_id String  @db.Uuid
  symptom_name      String  @db.VarChar(255)
  severity          Int     @db.SmallInt
  duration          String? @db.VarChar(100)

  triage_sessions triage_sessions @relation(fields: [triage_session_id], references: [id], map: "fk_symptom_session", onDelete: Cascade)

  @@index([triage_session_id], map: "idx_symptoms_session")
}

model vitals_readings {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id        String           @db.Uuid
  triage_session_id String?          @db.Uuid
  source_type       source_type_enum @default(MANUAL)
  heart_rate        Int?
  spo2              Int?
  systolic_bp       Int?
  diastolic_bp      Int?
  temperature       Decimal?         @db.Decimal(4, 1)
  respiratory_rate  Int?
  recorded_at       DateTime         @default(now()) @db.Timestamptz(6)

  patients        patients         @relation(fields: [patient_id], references: [id], map: "fk_vitals_patient")
  triage_sessions triage_sessions? @relation(fields: [triage_session_id], references: [id], map: "fk_vitals_session", onDelete: SetNull)

  @@index([patient_id], map: "idx_vitals_patient")
  @@index([triage_session_id], map: "idx_vitals_session")
}

// --- AI Hospital Intelligence Engine (Phase 4) -----------------------------
//
// Doctor Availability and Insurance Compatibility (from the plan's scoring
// formula) are simplified here since Doctor Management (Phase 10) and a
// hospital<->insurer join table don't exist yet: doctor counts live directly
// on hospital_operational_status, and accepted insurers are a plain string
// list on hospitals. See the Phase 4 plan doc for the full rationale.

model hospitals {
  id                          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String             @db.VarChar(255)
  hospital_type               hospital_type_enum @default(PRIVATE)
  address_line_1              String?            @db.VarChar(255)
  city                        String?            @db.VarChar(100)
  state                       String?            @db.VarChar(100)
  latitude                    Decimal            @db.Decimal(9, 6)
  longitude                   Decimal            @db.Decimal(9, 6)
  emergency_supported         Boolean            @default(false)
  verified                    Boolean            @default(false)
  contact_number               String?            @db.VarChar(20)
  reliability_score            Decimal            @default(0.80) @db.Decimal(3, 2)
  accepted_insurance_providers String[]
  created_at                   DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime           @default(now()) @updatedAt @db.Timestamptz(6)

  departments              departments[]
  operational_status       hospital_operational_status?
  specialties              hospital_specialties[]
  hospital_recommendations hospital_recommendations[]
  doctors                  doctors[]
  appointments             appointments[]
  pharmacies               pharmacies[]

  @@index([city], map: "idx_hospitals_city")
}

model departments {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id     String  @db.Uuid
  department_name String  @db.VarChar(150)
  description     String?

  hospitals    hospitals      @relation(fields: [hospital_id], references: [id], map: "fk_department_hospital", onDelete: Cascade)
  appointments appointments[]

  @@index([hospital_id], map: "idx_departments_hospital")
}

model hospital_operational_status {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id         String   @unique @db.Uuid
  available_beds      Int      @default(0)
  total_beds          Int      @default(0)
  available_icu       Int      @default(0)
  total_icu           Int      @default(0)
  available_doctors   Int      @default(0)
  total_doctors       Int      @default(0)
  emergency_load      Int      @default(0)
  queue_load          Int      @default(0)
  ventilators_available Int    @default(0)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  hospitals hospitals @relation(fields: [hospital_id], references: [id], map: "fk_operational_status_hospital", onDelete: Cascade)
}

model hospital_specialties {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id       String @db.Uuid
  specialization_id Int    @db.SmallInt

  hospitals              hospitals              @relation(fields: [hospital_id], references: [id], map: "fk_specialty_hospital", onDelete: Cascade)
  doctor_specializations doctor_specializations @relation(fields: [specialization_id], references: [id], map: "fk_specialty_specialization")

  @@unique([hospital_id, specialization_id])
  @@index([hospital_id], map: "idx_hospital_specialties_hospital")
}

model hospital_recommendations {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id             String   @db.Uuid
  triage_session_id      String?  @db.Uuid
  hospital_id            String   @db.Uuid
  recommendation_score   Decimal  @db.Decimal(5, 2)
  eta_minutes            Int
  wait_time_minutes      Int
  recommendation_reason  String
  created_at             DateTime @default(now()) @db.Timestamptz(6)

  patients        patients         @relation(fields: [patient_id], references: [id], map: "fk_recommendation_patient")
  hospitals       hospitals        @relation(fields: [hospital_id], references: [id], map: "fk_recommendation_hospital")
  triage_sessions triage_sessions? @relation(fields: [triage_session_id], references: [id], map: "fk_recommendation_session", onDelete: SetNull)

  @@index([patient_id], map: "idx_recommendations_patient")
  @@index([hospital_id], map: "idx_recommendations_hospital")
  @@index([triage_session_id], map: "idx_recommendations_session")
}

// --- Appointment Booking & Queue Management (Phase 5) ----------------------
//
// doctors is the minimal prerequisite entity this phase needed: no Doctor
// Management phase exists in the plan before this one, so hospital_id and
// specialization_id start nullable (JIT-provisioned bare on role selection,
// same as patients) and get filled in via the doctor's own onboarding form.

model doctors {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String   @unique @db.Uuid
  hospital_id         String?  @db.Uuid
  specialization_id   Int?     @db.SmallInt
  license_number      String?  @db.VarChar(100)
  experience_years    Int?
  consultation_fee    Decimal? @db.Decimal(10, 2)
  availability_status Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  users                  users                   @relation(fields: [user_id], references: [id], map: "fk_doctor_user")
  hospitals              hospitals?              @relation(fields: [hospital_id], references: [id], map: "fk_doctor_hospital")
  doctor_specializations doctor_specializations? @relation(fields: [specialization_id], references: [id], map: "fk_doctor_specialization")
  schedules              doctor_schedules[]
  appointments           appointments[]

  @@index([hospital_id], map: "idx_doctors_hospital")
  @@index([specialization_id], map: "idx_doctors_specialization")
}

model doctor_schedules {
  id                    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctor_id             String @db.Uuid
  day_of_week           Int    @db.SmallInt
  start_time            String @db.VarChar(5)
  end_time              String @db.VarChar(5)
  slot_duration_minutes Int    @default(15)

  doctors doctors @relation(fields: [doctor_id], references: [id], map: "fk_schedule_doctor", onDelete: Cascade)

  @@index([doctor_id], map: "idx_schedules_doctor")
}

model appointments {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id         String                  @db.Uuid
  doctor_id          String                  @db.Uuid
  hospital_id        String                  @db.Uuid
  department_id      String?                 @db.Uuid
  appointment_date   DateTime                @db.Timestamptz(6)
  appointment_type   appointment_type_enum   @default(CONSULTATION)
  appointment_status appointment_status_enum @default(SCHEDULED)
  priority_level     urgency_level_enum      @default(LOW)
  triage_session_id  String?                 @db.Uuid
  created_at         DateTime                @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                @default(now()) @updatedAt @db.Timestamptz(6)

  patients        patients         @relation(fields: [patient_id], references: [id], map: "fk_appointment_patient")
  doctors         doctors          @relation(fields: [doctor_id], references: [id], map: "fk_appointment_doctor")
  hospitals       hospitals        @relation(fields: [hospital_id], references: [id], map: "fk_appointment_hospital")
  departments     departments?     @relation(fields: [department_id], references: [id], map: "fk_appointment_department")
  triage_sessions triage_sessions? @relation(fields: [triage_session_id], references: [id], map: "fk_appointment_triage", onDelete: SetNull)
  queue_entry     queue_entries?

  @@unique([doctor_id, appointment_date])
  @@index([patient_id], map: "idx_appointments_patient")
  @@index([doctor_id], map: "idx_appointments_doctor")
  @@index([hospital_id], map: "idx_appointments_hospital")
}

model queue_entries {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id String            @unique @db.Uuid
  queue_position Int
  estimated_wait Int
  actual_wait    Int?
  status         queue_status_enum @default(WAITING)
  created_at     DateTime          @default(now()) @db.Timestamptz(6)
  updated_at     DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  appointments appointments @relation(fields: [appointment_id], references: [id], map: "fk_queue_appointment", onDelete: Cascade)
}

// --- Pharmacy Lookup & Medicine Search (Phase 6) ---------------------------
//
// No pharmacy-staff role exists in this app's RBAC (patient/doctor/hospital/
// admin only) — inventory management is Admin-gated instead of a dedicated
// pharmacy dashboard, the same restraint applied elsewhere rather than
// building unused role infrastructure early.

model pharmacies {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id    String?  @db.Uuid
  pharmacy_name  String   @db.VarChar(255)
  address_line_1 String?  @db.VarChar(255)
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  latitude       Decimal  @db.Decimal(9, 6)
  longitude      Decimal  @db.Decimal(9, 6)
  verified       Boolean  @default(false)
  contact_number String?  @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  hospitals             hospitals?              @relation(fields: [hospital_id], references: [id], map: "fk_pharmacy_hospital")
  inventory             pharmacy_inventory[]
  medicine_reservations medicine_reservations[]

  @@index([city], map: "idx_pharmacies_city")
  @@index([hospital_id], map: "idx_pharmacies_hospital")
}

model pharmacy_inventory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pharmacy_id    String   @db.Uuid
  medicine_id    String   @db.Uuid
  stock_quantity Int      @default(0)
  is_available   Boolean  @default(true)
  last_updated   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  pharmacies pharmacies @relation(fields: [pharmacy_id], references: [id], map: "fk_inventory_pharmacy", onDelete: Cascade)
  medicines  medicines  @relation(fields: [medicine_id], references: [id], map: "fk_inventory_medicine", onDelete: Cascade)

  @@unique([pharmacy_id, medicine_id])
  @@index([medicine_id], map: "idx_inventory_medicine")
}

model medicine_reservations {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id   String                    @db.Uuid
  pharmacy_id  String                    @db.Uuid
  medicine_id  String                    @db.Uuid
  quantity     Int
  status       reservation_status_enum   @default(PENDING)
  pickup_code  String                    @db.VarChar(10)
  created_at   DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)

  patients   patients   @relation(fields: [patient_id], references: [id], map: "fk_reservation_patient")
  pharmacies pharmacies @relation(fields: [pharmacy_id], references: [id], map: "fk_reservation_pharmacy")
  medicines  medicines  @relation(fields: [medicine_id], references: [id], map: "fk_reservation_medicine")

  @@index([patient_id], map: "idx_reservations_patient")
  @@index([pharmacy_id], map: "idx_reservations_pharmacy")
}

