generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model doctor_specializations {
  id                  Int     @id @default(autoincrement()) @db.SmallInt
  specialization_name String  @unique @db.VarChar(100)
  description         String?
}

model medicines {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  generic_name String    @db.VarChar(255)
  brand_name   String?   @db.VarChar(255)
  manufacturer String?   @db.VarChar(255)
  dosage_form  String?   @db.VarChar(100)
  strength     String?   @db.VarChar(100)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model roles {
  id          Int      @id @default(autoincrement()) @db.SmallInt
  role_name   String   @unique @db.VarChar(50)
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users[]
}

model system_configuration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  config_key   String    @unique @db.VarChar(100)
  config_value String
  description  String?
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

// id is Neon Auth's external user id (JWT `sub` claim) rather than a
// self-generated UUID: Neon Auth owns identity/credentials, this table only
// holds MediLink-domain data and is JIT-provisioned via /auth/complete-profile
// on first authenticated request.
model users {
  id                String              @id @db.Uuid
  role_id           Int                 @db.SmallInt
  email             String?             @unique @db.VarChar(255)
  phone             String?             @unique @db.VarChar(20)
  is_email_verified Boolean             @default(false)
  is_phone_verified Boolean             @default(false)
  account_status    account_status_enum @default(ACTIVE)
  last_login        DateTime?           @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  roles             roles               @relation(fields: [role_id], references: [id], map: "fk_user_role")

  @@index([email], map: "idx_users_email")
  @@index([phone], map: "idx_users_phone")
  @@index([role_id], map: "idx_users_role")
  @@index([account_status], map: "idx_users_status")
}

enum account_status_enum {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum alert_severity_enum {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum appointment_status_enum {
  SCHEDULED
  CHECKED_IN
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum appointment_type_enum {
  CONSULTATION
  FOLLOW_UP
  EMERGENCY
  TELECONSULTATION
}

enum blood_group_enum {
  A_POS   @map("A+")
  A_NEG   @map("A-")
  B_POS   @map("B+")
  B_NEG   @map("B-")
  AB_POS  @map("AB+")
  AB_NEG  @map("AB-")
  O_POS   @map("O+")
  O_NEG   @map("O-")
  UNKNOWN
}

enum consent_status_enum {
  ACTIVE
  REVOKED
  EXPIRED
}

enum consultation_mode_enum {
  ONLINE
  OFFLINE
  BOTH
}

enum gender_enum {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum hospital_type_enum {
  GOVERNMENT
  PRIVATE
  TRUST
  MILITARY
  SPECIALTY
}

enum notification_type_enum {
  GENERAL
  SYSTEM
  APPOINTMENT
  EMERGENCY
  REMINDER
}

enum queue_status_enum {
  WAITING
  CALLED
  IN_CONSULTATION
  COMPLETED
  CANCELLED
}

enum record_type_enum {
  CONSULTATION
  FOLLOW_UP
  EMERGENCY
  SURGERY
  TELECONSULTATION
}

enum source_type_enum {
  MANUAL
  SIMULATED
  DEVICE
}

enum triage_status_enum {
  STARTED
  COMPLETED
  CANCELLED
}

enum urgency_level_enum {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}
