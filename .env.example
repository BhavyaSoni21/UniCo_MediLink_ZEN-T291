# Copy this file to `.env` at the repo root and fill in real values.
# Never commit the real `.env` file — it is already gitignored.

# ======================
#  Database (local PostgreSQL)
# ======================
DATABASE_URL="postgresql://medilink:medilink@localhost:5432/medilink"

# ======================
#  Auth (local JWT)
# ======================
AUTH_SECRET=change-me-in-production

# ======================
#  Backend (NestJS) API
# ======================
NODE_ENV=development
PORT=3000

# ======================
#  Redis (cache / pubsub)
# ======================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================
#  Object Storage (MinIO)
# ======================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medilink-reports

# ======================
#  AI Service (FastAPI)
# ======================
AI_SERVICE_PORT=8000
# How the NestJS API reaches the AI service — localhost for `npm run dev`,
# the docker-compose service name when running via `docker compose up`.
AI_SERVICE_URL=http://localhost:8000

# ======================
#  Frontend (Next.js)
# ======================
FRONTEND_PORT=3001
API_BASE_URL=http://localhost:3000/api/v1
